#!/usr/bin/env bash
# Pre-commit hook: run the new BG-scene regression tests before letting any
# commit through. These tests catch the most common ROM-side palette
# regressions (scene_detect dispatch wrong, banner_override/cutscene_override
# fill ranges wrong, splash table not loaded). Each test runs a headless
# mGBA in ~5s; total wall-clock ~15-20s for the 3 tests below.
#
# Install once with:
#   ln -sfn ../../scripts/hooks/pre-commit .git/hooks/pre-commit
#
# Skip with `git commit --no-verify` if you need to commit work-in-progress
# that you know will not pass yet.
#
# This intentionally does NOT run the full color_regression_tests.yaml suite
# (~18 OBJ tests) because of the well-known mGBA Lua "frame" callback timing
# issue that produces false positives on single-frame OAM reads. Once that's
# fixed (planned: scanline callback or busy-loop+retry), this hook can be
# expanded to the full suite.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Detect whether the ROM-side build files were touched. If not, the regression
# tests have nothing new to validate — skip to keep the hook fast.
CHANGED=$(git diff --cached --name-only)
if ! echo "$CHANGED" | grep -qE 'scripts/(build_v301|build_v296|bg_experiment|create_vblank|run_color|diagnostics/test_fresh_boot|hooks/pre-commit)|tests/color_regression|palettes/.*\.yaml|rom/working/'; then
  echo "[pre-commit] No build/test/palette changes staged — skipping regression suite."
  exit 0
fi

ROM="rom/working/penta_dragon_dx_teleport.gb"
if [[ ! -f "$ROM" ]]; then
  echo "[pre-commit] $ROM missing — building..."
  uv run python scripts/build_v301_teleport.py > /tmp/precommit_build.log 2>&1 \
    || { echo "[pre-commit] BUILD FAILED — see /tmp/precommit_build.log"; exit 1; }
fi

echo "[pre-commit] Verifying hook-tests ↔ YAML integrity..."
uv run python scripts/diagnostics/verify_hook_tests_exist.py \
  || { echo "[pre-commit] hook-vs-YAML check FAILED — see output above"; exit 1; }

echo "[pre-commit] Verifying iter-31/39/40 ROM bytes (teleport + v3.01)..."
uv run python scripts/diagnostics/verify_colorizer_bytes.py --rom "$ROM" \
  || { echo "[pre-commit] ROM byte verification FAILED (teleport) — see output above"; exit 1; }
V301_ROM="rom/working/penta_dragon_dx_v301.gb"
if [[ -f "$V301_ROM" ]]; then
  uv run python scripts/diagnostics/verify_colorizer_bytes.py --rom "$V301_ROM" \
    || { echo "[pre-commit] ROM byte verification FAILED (v3.01) — see output above"; exit 1; }
fi

echo "[pre-commit] Running regression tests against $ROM..."
# Tests selected for the hook are the ones VERIFIED to pass reliably on the
# current wip-color-sweep build. Tests that fail due to pre-existing test-
# data issues (e.g., gargoyle YAML says "expected pal7 but intended pal6")
# are intentionally excluded until the YAML is corrected. The consensus
# OAM filter (commit 457cc73) lets us include sara_w_alone in the hook —
# it was failing before due to the Lua frame-callback timing artifact.
TESTS=(
  # BG scene-dispatch tests (verify scene_detect routes the right D880 to the
  # right bg_table + per-scene overrides patch 0xDA00 correctly):
  banner_bg_table_palettes
  cutscene_bg_table_palettes
  splash_bg_table_all_pal0
  postboss_reload_bg_table_all_pal0
  miniboss_uses_dungeon_table
  dungeon_uses_dungeon_table
  # Iter 16: hazard + wall + item bg_table regression tests. These verify
  # the dungeon table maps spike tiles (0x2A-0x2E, 0x3A-0x3D) to pal 6
  # (metallic, not lava), wall corners (0x47/0x57 etc.) to pal 6 (not the
  # 2026-05-23 orange regression), and items+font (0x80-0xDF) to pal 1
  # (uniform red). Catches anyone who reverts _bg_table() in build_v301_gdma.
  dungeon_table_spikes_metallic
  dungeon_table_wall_corners
  dungeon_table_items_and_font
  # Iter 17: stage-5/7 LAVA override + FFBA guard regression. Verifies the
  # build_lava_override at bank13:0x7E00 patches molten tile IDs to pal 5
  # when FFBA = 4 or 6, AND that the FFBA guard prevents the override from
  # leaking into stage 1 (FFBA=0). Catches anyone who disables the per-frame
  # CALL, breaks the FFBA dispatch, or weakens the guard.
  lava_stage5_override
  lava_stage7_override
  lava_off_at_ffba0
  # Iter 18: per-arena bg_table CONTENT tests. The *_arena_dispatch tests
  # only check "tile 0x00 = pal 0" (catches off-by-one in dispatch math
  # but NOT arena-table corruption). These verify signature tile→palette
  # mappings unique to each boss arena (e.g. Shalamar crown 0x11 → pal 4
  # cyan, Penta Dragon red head 0x48 → pal 5). Together with the dispatch
  # tests, they pin down both the routing AND the contents.
  shalamar_arena_content
  riff_arena_content
  crystal_dragon_arena_content
  cameo_arena_content
  ted_arena_content
  troop_arena_content
  faze_arena_content
  angela_arena_content
  penta_dragon_arena_content
  # Iter 20: scene-routing tests for D880 values that scene_detect should
  # default to the DUNGEON table (i.e., NOT in the splash_body list at
  # 0x16/0x18/0x1B and NOT in the arena range 0x0C-0x14). Catches anyone
  # who accidentally adds these to splash dispatch or the arena range.
  death_uses_dungeon_table
  victory_intermediate_uses_dungeon_table
  victory_final_uses_dungeon_table
  title_menu_uses_dungeon_table
  # Iter 30: more scene-routing tests for D880 values that should default
  # to the DUNGEON table (i.e., NOT in splash_body list at 0x16/0x18/0x1B
  # and NOT in arena range 0x0C-0x14). Catches anyone who accidentally
  # adds these to splash dispatch.
  title_screen_uses_dungeon_table
  shmup_secret_stage_uses_dungeon_table
  # All 9 boss arena dispatches (D880 = 0x0C..0x14):
  shalamar_arena_dispatch
  riff_arena_dispatch
  crystal_dragon_arena_dispatch
  cameo_arena_dispatch
  ted_arena_dispatch
  troop_arena_dispatch
  faze_arena_dispatch
  angela_arena_dispatch
  penta_dragon_arena_dispatch
  # OBJ tests (all verified reliable on wip-color-sweep via consensus filter):
  sara_w_alone
  sara_d_alone
  crow
  sara_d_hornet_or_moth
  jet_form_secret_stage
  spiral_power_active
  # Iter 10: WRAM STAT-IRQ stub (be7d5e3 + this) fixes Sara slot-1
  # alternation in boss fights, unlocking these previously-flaky tests:
  moth
  gargoyle_miniboss
  # Iter 27: test-runner bug fix unblocked these. Previously `frame_count
  # >= target_frames + 8` caused record_oam_sample to be called every
  # frame after f=68 (hundreds of extra samples) until mGBA timed out.
  # Consensus then voted across hundreds of post-target samples instead of
  # the intended 5. Fix was `>=` → `==`. After the fix:
  mage
  metal_ball_mage_soldier
  hornets
  # Iter 28: expand coverage to scenes not previously tested in hook.
  # sweep_untested_savestates.sh found these are correctly colorized:
  #  - D880=0x0B item-pickup scene (hwoam_recolor gate is < 0x0C so it fires)
  #  - Pulsing-BG state (VRAM in flux, Sara colorize must hold)
  #  - D880=0x09 / FFBA=7 SHMUP secret stage (previously untested)
  sara_w_item_pickup_scene
  sara_w_pulsing_vram
  sara_w_secret_stage_shmup
  # Iter 31: hwoam_recolor B 10 → 40 + tile 0x10-0x1F → sara_palette
  # unlocks ALL previously-excluded slot-10+ enemy tests. Sara secondary
  # tiles map to D (Sara pal) instead of pal_4, avoiding "Sara half-orange"
  # while the post-DMA stamp coats slots 10+ with their correct tile-range
  # palettes (orc → pal 5, soldier → pal 6, etc.). The audit's pessimistic
  # "DMA-race needs MiSTer fix" was actually solvable by post-stamping HW
  # OAM AFTER the DMA instead of trying to win the shadow-pass race.
  orc
  orc_with_items
  soldier
  catfish
  spider_miniboss_sara_d
  dragon_powerup
  # Iter 32: more sweep-discovered tests covering unique scene combinations.
  # The sara_w_in_spider_miniboss_live test is the LIVE-savestate counter-
  # example to spider_miniboss_sara_w's frozen failure — proves iter 31's
  # B=40 fix DOES handle the spider scene when the savestate isn't frozen.
  sara_w_in_spider_miniboss_live
  sara_d_teleport_tile
  sara_w_dual_enemies_with_arrows
  # Iter 33: 2 more sweep-discovered tests covering Sara D + enemy and
  # form-change + non-Sara-enemy combinations.
  sara_d_metal_ball_enemy
  sara_w_dragon_powerup_with_crow
  # Iter 35: 3 more sweep-discovered tests for unique scene combinations
  # (Sara D + non-Sara enemy; secret-stage transition window FFC1=0;
  # multi-enemy stress with arrows + items).
  sara_d_with_soldier
  sara_w_secret_stage_transition
  sara_w_catfish_with_arrows_items
  # Iter 37: Sara alt-anim frame validation (tile 0x28-0x2B instead of
  # 0x20-0x23). Locks down that the sara_palette mapping covers the FULL
  # 0x20-0x2F range, not just the rest-pose subset.
  sara_w_diagonal_arrows_alt_anim
  # Iter 47: 2 more sweep-discovered tests.
  sara_w_miniboss_dying
  sara_d_turbo_powerup_active
  # Iter 54: last excluded YAML test unlocked. The old
  # level1_sara_w_spier_miniboss.ss0 capture was frozen — made before the
  # WRAM cold-boot stubs existed, so STAT-IRQ at 0x0048→JP 0xDB50 fell
  # into zeroed WRAM and blocked the colorize wrapper chain. Switched the
  # savestate to level1_sara1_shield1_item_spider_miniboss.ss0 which has
  # the stub block populated (DB00-DB60 non-zero). 68/68 YAML coverage now.
  spider_miniboss_sara_w
  # Iter 55: sweep-discovered tests from previously-unused .ss0 captures.
  # Each adds a tile/pal combination not present in prior tests:
  #   thrusting_spike_hazard — D880=0x0B FFBF=0 + spike tiles 0x54-0x57 pal 5
  #   2_metal_ball          — 2 metal balls (tiles 0x40-0x43 pal 4)
  #   teleport_animation    — Sara mid-teleport (tiles 0x2C-0x2F pal 2)
  #   pulsing_bg_with_enemies — BG-transition + soldiers (0x60-0x63 pal 6) + orcs
  sara_w_thrusting_spike_hazard
  sara_w_2_metal_ball
  sara_w_teleport_animation
  sara_w_pulsing_bg_with_enemies
  # Iter 57: BG-only pixel-based test. The PENTA DRAGON DX title menu
  # has no OAM sprites, so the existing slot/tile_range expectations have
  # nothing to assert. The new pixel_expectations type counts RGB pixels
  # in the rendered screenshot — guards the BG palette CRAM load + scene
  # routing for D880=0x1C (catches anyone who breaks the dungeon-table
  # default for menu, or the BG palette load that puts dark red in BGP1).
  titlemenu_colored
  # Iter 58: visual fidelity tests — Sara baseline savestates rendered
  # at f=300 to skip the DF1F transient (iter 53). Catches OBP 2/1 CRAM
  # regressions that the OAM tests miss (a wrong CRAM color renders Sara
  # gray even when OAM attr correctly says pal 2).
  sara_w_pink_render
  sara_d_green_render
  # Iter 67: complement to sara_w_pink_render — force_df1f=0 path covers
  # cond_pal's load logic independent of the DF1F drain mechanism. If
  # someone breaks force_df1f or cond_pal's OBP-2 branch, this fails
  # before the f=300-based pink_render does.
  sara_w_pink_force_df1f
  # Iter 59: visual fidelity for mini-bosses, SHMUP secret stage, and a
  # lava-flood regression check on stage 1. The arena_content tests
  # already cover bg_table mapping; these cover the *rendered* CRAM.
  gargoyle_visual_render
  spider_visual_render
  jet_form_visual_render
  stage1_no_lava_flood
  # Iter 101: three more item-scene tests using previously-unused .ss0
  # captures (sweep of 5 unused saves; one — sara_w_2_soldier — was
  # flaky and skipped). Each covers a distinct item type at a stable
  # frame=68 sample (5/5 zero-jitter): rock item, flash item, extra-life.
  sara_w_rock_item
  sara_w_flash_item
  sara_w_extra_life_item
  # Iter 102: four more scenes from the unused-saves sweep continued.
  # multi_arrow_items has the biggest red render in the suite (630
  # pixels — 4 arrow item types onscreen at once). spiral_active_low_health
  # covers spiral-power + 1HP corner case. spiral_powerup_item_render
  # captures a transient Sara form-change state with the green item tile.
  # catfish_menu_open covers menu-overlay layer rendering.
  sara_w_multi_arrow_items
  sara_w_spiral_active_low_health
  sara_spiral_powerup_item_render
  sara_w_catfish_menu_open
  # Iter 103: four more from unused-saves sweep continued.
  # sara_d_special_spiral_weapon: distinctive #007300 dark-green projectile
  # render — only test in suite asserting on that specific color.
  # sara_w_gray_monster_pink_projectile: explicit Sara W pink CRAM
  # verification (#FF42A5=60 OBP2 idx 1).
  # sara_w_square_arrows_combo + sara_w_health_items_wild_card: dense
  # multi-item scenes (red render 296 and 519 pixels respectively).
  sara_d_special_spiral_weapon
  sara_w_gray_monster_pink_projectile
  sara_w_square_arrows_combo
  sara_w_health_items_wild_card
  # Iter 104: pre-secret-stage transition Sara at tiles 0x28-0x2B with
  # menu overlay active. Verifies sara_palette tile-range mapping for
  # the 0x28-0x2F sub-band (existing sara_w_diagonal_arrows_alt_anim
  # covers a similar but different sub-band). Also asserts on the
  # OBP-2 CRAM at a different sampling moment than sara_w_pink_render's
  # f=300 — catches different regression classes.
  sara_w_right_before_secret_stage_gbc
  # Iter 105: .2 variants of moth/p_item — NOT duplicates (different
  # file sizes/hashes vs originals). moth_alt has a different enemy
  # combo (orange+yellow vs blue+yellow); p_item_alt is in D880=0x02
  # dungeon scene (vs original p_item's D880=0x0B pickup state).
  sara_w_moth_alt_scene
  sara_w_p_item_alt_scene
)
# Iter 19: parallelize the suite (xargs -P) and switch to a deterministic
# post-hoc summary via .ok/.fail markers.
#
# Wall-clock observation (80 tests, iter 69):
#   P=4   = 10:09  (the original cap, set in iter 19 with 38 tests)
#   P=8   =  5:07  (2× faster)
#   P=12  =  3:34  (~3× faster — current setting)
#   P=16  =  3:03  (diminishing returns; xvfb / OS scheduler contention)
# The mGBA Qt init / xvfb-run per-launch overhead used to dominate (per the
# iter-19 finding), but a 80-test suite makes the CPU work matter much more
# than at 38 tests. Cap raised to P=12 — still leaves CPU headroom on a
# 24-core machine and on 4-core CI nodes it falls back to nproc=4 anyway.
NPROC=$(nproc 2>/dev/null || echo 4)
PARALLEL=$((NPROC > 12 ? 12 : NPROC))
echo "[pre-commit] Running ${#TESTS[@]} tests with up to $PARALLEL parallel workers..."

printf '%s\n' "${TESTS[@]}" | xargs -I {} -P "$PARALLEL" bash -c '
  t="$1"
  rom="$2"
  if QT_QPA_PLATFORM=offscreen SDL_AUDIODRIVER=dummy xvfb-run -a \
       uv run python scripts/run_color_regression.py --rom "$rom" --test "$t" \
       > "/tmp/precommit_${t}.log" 2>&1; then
    : > "/tmp/precommit_${t}.ok"
  else
    : > "/tmp/precommit_${t}.fail"
  fi
' _ {} "$ROM"

FAILED=()
for t in "${TESTS[@]}"; do
  if [[ -e "/tmp/precommit_${t}.fail" ]]; then
    FAILED+=("$t")
    echo "  [FAIL] $t — see /tmp/precommit_${t}.log"
    rm -f "/tmp/precommit_${t}.fail"
  else
    echo "  [PASS] $t"
    rm -f "/tmp/precommit_${t}.ok"
  fi
done

if [[ ${#FAILED[@]} -gt 0 ]]; then
  echo
  echo "[pre-commit] ${#FAILED[@]} regression test(s) failed — blocking commit."
  echo "[pre-commit] To override (e.g., for WIP), use: git commit --no-verify"
  exit 1
fi

echo "[pre-commit] All BG-scene regression tests passed."

# Iter 75: fresh-boot end-to-end test. All YAML tests use savestates,
# whose captured CRAM persists through the test sample window — so
# they pass even if the ROM palette source is corrupted (see iter
# 70/73/74 + project_adversarial_coverage.md). This script does a
# cold-boot, auto-presses the title-menu input sequence, and verifies
# Sara W renders pink + peach at f=1500. Adds ~30s wall-clock.
echo "[pre-commit] Running fresh-boot end-to-end test..."
if ! uv run python scripts/diagnostics/test_fresh_boot.py 2>&1 | tail -8; then
  echo "[pre-commit] Fresh-boot test FAILED — likely a SaraWitch ROM palette regression."
  exit 1
fi

exit 0
